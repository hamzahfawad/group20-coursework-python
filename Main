import random
import math

# CLASS: Area
# represents one area
class Area:
    def __init__(self, area_type, number):
        self.area_type = area_type    
        self.number = number            
        self.name = f"{area_type}-{number}"

        self.damage = 0                 # current damage level
        self.assigned_worker = None     # worker currently fixing this area

        # Stats tracking
        self.turns_operational = 0
        self.turns_being_repaired = 0
        self.turns_damaged_unassigned = 0

    def is_working(self):
        # area is working if damage = 0
        return self.damage == 0

    def is_being_repaired(self):
        return self.assigned_worker is not None

    def apply_damage(self, amount):
        # give this area a damage value
        self.damage = amount

    def apply_repair(self):
        # worker does their repair this turn
        if self.assigned_worker is not None:
            repair_rate = self.assigned_worker.get_repair_rate(self.area_type)
            self.damage -= repair_rate

            # if damage is 0 or less, area is fixed
            if self.damage <= 0:
                self.damage = 0
                self.assigned_worker.finish_job(self.area_type)  # worker becomes available
                self.assigned_worker = None

    def update_stats(self):
        # called each turn to track how time is being spent
        if self.is_working():
            self.turns_operational += 1
        elif self.is_being_repaired():
            self.turns_being_repaired += 1
        else:
            self.turns_damaged_unassigned += 1

    def print_stats(self):
        print(f"  {self.name}:")
        print(f"    Operational turns:          {self.turns_operational}")
        print(f"    Being repaired turns:        {self.turns_being_repaired}")
        print(f"    Damaged (unassigned) turns:  {self.turns_damaged_unassigned}")


# CLASS: Worker
# represents one employee
class Worker:
    def __init__(self, name, rate_a, rate_b, rate_c):
        self.name = name

        # how much damage they fix per turn for each type
        self.repair_rates = {
            'TypeA': rate_a,
            'TypeB': rate_b,
            'TypeC': rate_c
        }

        self.current_job = None  # area they are currently working on (None means they are free)

        # stats tracking
        self.turns_worked = {'TypeA': 0, 'TypeB': 0, 'TypeC': 0}
        self.jobs_completed = {'TypeA': 0, 'TypeB': 0, 'TypeC': 0}
        self.turns_idle = 0

    def is_available(self):
        return self.current_job is None

    def get_repair_rate(self, area_type):
        return self.repair_rates[area_type]

    def turns_to_fix(self, area):
        # how many full turns would this worker take to fix this area?
        rate = self.repair_rates[area.area_type]
        return math.ceil(area.damage / rate)

    def assign_job(self, area):
        # assign this worker to an area
        self.current_job = area
        area.assigned_worker = self

    def finish_job(self, area_type):
        # called when repair is done - updates stats and frees worker
        self.jobs_completed[area_type] += 1
        self.current_job = None

    def update_stats(self):
        # called each turn to log working/idle time
        if self.current_job is not None:
            area_type = self.current_job.area_type
            self.turns_worked[area_type] += 1
        else:
            self.turns_idle += 1

    def print_stats(self):
        status = "Currently repairing" if self.current_job else "Not repairing"
        print(f"  {self.name}:")
        print(f"    Turns worked - TypeA: {self.turns_worked['TypeA']}, "
              f"TypeB: {self.turns_worked['TypeB']}, TypeC: {self.turns_worked['TypeC']}")
        print(f"    Jobs completed - TypeA: {self.jobs_completed['TypeA']}, "
              f"TypeB: {self.jobs_completed['TypeB']}, TypeC: {self.jobs_completed['TypeC']}")
        print(f"    Turns idle: {self.turns_idle}")
        print(f"    Status: {status}")
# CLASS: Simulation
# runs the whole thing
class Simulation:
    def __init__(self, num_turns, area_counts, probabilities, damage_range, worker_data):
        self.num_turns = num_turns
        self.probabilities = probabilities      # dict: type -> probability of damage each turn
        self.damage_min = damage_range[0]       # best case damage
        self.damage_max = damage_range[1]       # worst case damage

        # create all the area objects
        self.areas = []
        for area_type, count in area_counts.items():
            for i in range(1, count + 1):
                self.areas.append(Area(area_type, i))

        # create all the worker objects
        self.workers = []
        for (name, ra, rb, rc) in worker_data:
            self.workers.append(Worker(name, ra, rb, rc))

    def get_available_workers(self):
        return [w for w in self.workers if w.is_available()]

    def get_unassigned_damaged_areas(self):
        # areas that are damaged but havent been assigned a worker yet
        return [a for a in self.areas if not a.is_working() and not a.is_being_repaired()]

    def allocate_jobs(self):
        """
        Assign workers to damaged unassigned areas.
        Company rule:
        - Find the single (worker, area) combo with the shortest fix time
        - Assign that worker to that area
        - Repeat with remaining workers and areas
        """
        unassigned_areas = self.get_unassigned_damaged_areas()
        available_workers = self.get_available_workers()

        # keep going until we run out of workers or jobs
        while unassigned_areas and available_workers:
            best_time = None
            best_worker = None
            best_area = None

            # look at every combo of available worker and unassigned area
            for worker in available_workers:
                for area in unassigned_areas:
                    t = worker.turns_to_fix(area)
                    if best_time is None or t < best_time:
                        best_time = t
                        best_worker = worker
                        best_area = area

            # assign the best matching worker
            best_worker.assign_job(best_area)

            # remove them from the pool for this round of allocation
            available_workers.remove(best_worker)
            unassigned_areas.remove(best_area)

    def run(self):
        print("\n--- Simulation Starting ---\n")

        for turn in range(1, self.num_turns + 1):
            print(f"Turn {turn}:")

            # step 1: working areas can randomly get damaged
            for area in self.areas:
                if area.is_working():
                    prob = self.probabilities[area.area_type]
                    if random.random() < prob:
                        # random damage between the min and max (inclusive)
                        dmg = random.randint(self.damage_min, self.damage_max)
                        area.apply_damage(dmg)
                        print(f"  {area.name} got damaged! Damage level: {dmg}")

            # step 2: update stats
            for area in self.areas:
                area.update_stats()
            for worker in self.workers:
                worker.update_stats()

            # step 3: workers repair their assigned areas
            # we iterate over a copy because the assignments can change mid-loop
            for area in list(self.areas):
                if area.is_being_repaired():
                    area.apply_repair()
                    if area.is_working():
                        print(f"  {area.name} has been fully repaired!")

            # step 4: allocate available workers to unassigned damaged areas
            self.allocate_jobs()

            # show current assignments
            for area in self.areas:
                if area.is_being_repaired():
                    print(f"  {area.assigned_worker.name} assigned to {area.name} "
                          f"(damage remaining: {area.damage})")

            print()

        print("--- Simulation Complete ---\n")

    def print_results(self):
        print("=" * 50)
        print("FINAL RESULTS")
        print("=" * 50)

        print("\n--- Area Statistics ---")
        for area in self.areas:
            area.print_stats()

        print("\n--- Worker Statistics ---")
        for worker in self.workers:
            worker.print_stats()

# getting the user inputs
def get_user_inputs():
    print("=== Maintenance Simulation Setup ===\n")

    num_turns = int(input("How many turns to simulate? "))

    # area counts
    area_counts = {}
    for area_type in ['TypeA', 'TypeB', 'TypeC']:
        count = int(input(f"How many {area_type} areas are there? "))
        area_counts[area_type] = count

    # probabilities
    probabilities = {}
    for area_type in ['TypeA', 'TypeB', 'TypeC']:
        prob = float(input(f"Probability of {area_type} getting damaged each turn (0-1): "))
        probabilities[area_type] = prob

    # damage range (shared across all types)
    damage_min = int(input("Best case damage (minimum): "))
    damage_max = int(input("Worst case damage (maximum): "))
    damage_range = (damage_min, damage_max)

    # workers
    worker_data = []
    num_workers = int(input("How many workers? "))
    for i in range(num_workers):
        name = input(f"  Worker {i+1} name: ")
        ra = int(input(f"    {name}'s repair rate for TypeA: "))
        rb = int(input(f"    {name}'s repair rate for TypeB: "))
        rc = int(input(f"    {name}'s repair rate for TypeC: "))
        worker_data.append((name, ra, rb, rc))

    return num_turns, area_counts, probabilities, damage_range, worker_data

# MAIN - Entry point
def main():
    num_turns, area_counts, probabilities, damage_range, worker_data = get_user_inputs()

    # create and run the simulation
    sim = Simulation(num_turns, area_counts, probabilities, damage_range, worker_data)
    sim.run()
    sim.print_results()


if __name__ == "__main__":
    main()
